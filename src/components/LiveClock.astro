<span class="clock" data-clock>London --:--:--</span>

<script>
  const node = document.querySelector("[data-clock]");
  const formatter = new Intl.DateTimeFormat("en-GB", {
    timeZone: "Europe/London",
    hour: "2-digit",
    minute: "2-digit",
    second: "2-digit",
    hour12: false
  });
  const tick = () => {
    if (node) node.textContent = `London ${formatter.format(new Date())}`;
  };
  tick();
  window.setInterval(tick, 1000);
</script>
