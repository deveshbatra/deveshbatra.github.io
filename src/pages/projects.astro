---
import BaseLayout from "@layouts/BaseLayout.astro";
import ProjectCard from "@components/ProjectCard.astro";
import { projects } from "@data/projects";
const buckets = Array.from(new Set(projects.map((project) => project.bucket)));
---

<BaseLayout title="Projects" description="Selected research code, AI demos, casual webapps, and open-source projects.">
  <section class="page-hero"><div class="container"><p class="eyebrow">~/projects</p><h1>Research code, demos, and useful little things.</h1><p>Selected projects and placeholders for tools worth building next.</p></div></section>
  {buckets.map((bucket) => (
    <section class="section"><div class="container"><div class="section-head"><h2>{bucket}</h2></div><div class="grid cards">{projects.filter((project) => project.bucket === bucket).map((project) => <ProjectCard project={project} />)}</div></div></section>
  ))}
</BaseLayout>
<style>.cards{grid-template-columns:repeat(3,minmax(0,1fr))}@media(max-width:900px){.cards{grid-template-columns:1fr}}</style>
